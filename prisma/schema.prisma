generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

enum ContentType {
  SOFTWARE
  VIDEO
  POST
  UPCOMING
}

model ContentItem {
  id          String      @id @default(cuid())
  type        ContentType
  title       String
  description String      @default("")
  imageUrl    String?
  videoUrl    String?
  externalLink String?
  sortOrder   Int         @default(0)
  published   Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
